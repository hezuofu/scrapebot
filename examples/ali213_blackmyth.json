{
  "task_id": "ali213_blackmyth",
  "task_name": "游侠论坛 - 黑神话悟空版块全量采集",
  "task_desc": "论坛列表→帖子详情，多规则串联采集",
  "start_urls": [
    "https://game.ali213.net/forum-2615-1.html",
    "https://game.ali213.net/forum-2615-2.html",
    "https://game.ali213.net/forum-2615-3.html",
    "https://game.ali213.net/forum-2615-4.html",
    "https://game.ali213.net/forum-2615-5.html",
    "https://game.ali213.net/forum-2615-6.html",
    "https://game.ali213.net/forum-2615-7.html",
    "https://game.ali213.net/forum-2615-8.html",
